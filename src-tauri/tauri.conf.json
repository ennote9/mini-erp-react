{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mini-erp-react",
  "version": "0.1.0",
  "identifier": "com.shaxr.mini-erp-react",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "mini-erp-react",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "connect-src": "ipc: http://ipc.localhost http://ipc.tauri.app",
        "img-src": "'self' asset: http://asset.localhost https://asset.localhost blob: data:",
        "style-src": "'unsafe-inline' 'self'",
        "font-src": "'self' data:"
      },
      "devCsp": {
        "default-src": "'self' customprotocol: asset: http://localhost:* http://127.0.0.1:*",
        "connect-src": "ipc: http://ipc.localhost http://ipc.tauri.app ws://localhost:* ws://127.0.0.1:* ws://localhost:1420 http://localhost:* http://127.0.0.1:*",
        "img-src": "'self' asset: http://asset.localhost https://asset.localhost blob: data: http://localhost:* http://127.0.0.1:* data:",
        "style-src": "'unsafe-inline' 'self' http://localhost:* http://127.0.0.1:*",
        "script-src": "'self' 'unsafe-inline' 'unsafe-eval' http://localhost:* http://127.0.0.1:*"
      },
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$APPLOCALDATA/items/**"],
          "deny": []
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
