{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "opener:default",
    "opener:allow-open-path",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "$APPLOCALDATA/items/**" }]
    },
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-read-file",
    "fs:allow-remove",
    "fs:allow-stat",
    "fs:allow-write-file"
  ]
}
