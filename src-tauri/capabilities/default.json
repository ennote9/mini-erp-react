{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [{ "path": "$APPLOCALDATA/items/**" }]
    },
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPLOCALDATA/items" },
        { "path": "$APPLOCALDATA/items/**" },
        { "path": "$APPLOCALDATA/master-data" },
        { "path": "$APPLOCALDATA/master-data/**" },
        { "path": "$APPLOCALDATA/documents" },
        { "path": "$APPLOCALDATA/documents/**" },
        { "path": "$APPLOCALDATA/inventory" },
        { "path": "$APPLOCALDATA/inventory/**" }
      ]
    },
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-read-file",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-stat",
    "fs:allow-write-file"
  ]
}
